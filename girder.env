GIRDER_MONGO_URI="mongodb://mongodb:27017/girder?socketTimeoutMS=3600000"
GIRDER_NOTIFICATION_REDIS_URL="redis://redis:6379"
GIRDER_SETTING_CORE_CACHE_ENABLED=true
GIRDER_SETTING_CORE_CORS_ALLOW_ORIGIN=http://localhost:*
GIRDER_SETTING_WORKER_API_URL=http://girder:8080/api/v1

ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}

LARGE_IMAGE_CACHE_BACKEND=redis
LARGE_IMAGE_CACHE_REDIS_URL=redis:6379
LARGE_IMAGE_CACHE_TILESOURCE_MEMORY_PORTION=32
LARGE_IMAGE_CACHE_TILESOURCE_MAXIMUM=8
LARGE_IMAGE_SOURCE_VIPS_IGNORED_NAMES='(^[^.]*|\.(yml|yaml|json|svs|mrxs))$'
# Increase the allowed files that can be cached, as this is used for tiled frames
LARGE_IMAGE_MAX_THUMBNAIL_FILES=400
# Automatically try to use all files as large images.
LARGE_IMAGE_AUTO_SET=all
